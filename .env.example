# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=ims_db
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=changeme_strongpassword_here

# ── Backend ────────────────────────────────────────────────────────────────
# Used by FastAPI directly (not needed by Docker Compose — it builds it)
DATABASE_URL=postgresql+asyncpg://ims_user:changeme_strongpassword_here@db:5432/ims_db

# ── Frontend ───────────────────────────────────────────────────────────────
# For local dev (Vite), this is proxied — leave as localhost
# For Docker build, set to the public backend URL (e.g. https://ims-api.onrender.com)
VITE_API_BASE_URL=http://localhost:8000
